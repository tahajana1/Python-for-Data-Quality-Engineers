def string_count(x):
    lines = x.split("\n")
    result = []
    for line in lines:
        line = line.strip().capitalize()
    
        parts = line.split(". ")
        parts = [p.capitalize() for p in parts]
        result.append(". ".join(parts))
    
    x = "\n".join(result)
    
